<Window x:Class="Obstruo.UI.Auth.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Obstruo Security"
        Icon="/Resources/obstruo.ico"
        Width="420" Height="580"
        MinWidth="420" MinHeight="580"
        MaxWidth="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Loaded="Window_Loaded">

    <Window.Resources>

        <SolidColorBrush x:Key="BgBrush"          Color="#0D0D14"/>
        <SolidColorBrush x:Key="SurfaceBrush"     Color="#12121E"/>
        <SolidColorBrush x:Key="BorderBrush2"     Color="#1E1E32"/>
        <SolidColorBrush x:Key="AccentBrush"      Color="#7C3AED"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#6D28D9"/>
        <SolidColorBrush x:Key="TextPrimary"      Color="#F8F8FF"/>
        <SolidColorBrush x:Key="TextSecondary"    Color="#8B8BA7"/>
        <SolidColorBrush x:Key="ErrorBrush"       Color="#EF4444"/>
        <SolidColorBrush x:Key="WarnBrush"        Color="#F59E0B"/>
        <SolidColorBrush x:Key="SuccessBrush"     Color="#10B981"/>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"      Value="#7C3AED"/>
            <Setter Property="Foreground"      Value="#F8F8FF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="38"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#6D28D9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#2A1A4E"/>
                                <Setter Property="Foreground" Value="#4B4B6B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LinkBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#8B8BA7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   TextDecorations="Underline"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#F8F8FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputBox" TargetType="Control">
            <Setter Property="Background"      Value="#12121E"/>
            <Setter Property="Foreground"      Value="#F8F8FF"/>
            <Setter Property="BorderBrush"     Value="#1E1E32"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Padding"         Value="10,0"/>
        </Style>

    </Window.Resources>

    <Border Background="{StaticResource BgBrush}"
            CornerRadius="12"
            BorderBrush="#1E1E32"
            BorderThickness="1">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Drag bar -->
            <Border Grid.Row="0"
                    Height="36"
                    Background="Transparent"
                    MouseLeftButtonDown="DragBar_MouseLeftButtonDown">
                <Button Content="✕"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,12,0"
                        Width="24" Height="24"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#8B8BA7"
                        FontSize="13"
                        Cursor="Hand"
                        Click="CloseBtn_Click"/>
            </Border>

            <!-- Main content -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">

                <StackPanel Margin="36,0,36,32">

                    <!-- Header -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,28">
                        <TextBlock Text="OBSTRUO"
                                   FontSize="26" FontWeight="Black"
                                   Foreground="#F8F8FF"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="SECURITY"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="#7C3AED"
                                   HorizontalAlignment="Center"
                                   Margin="0,2,0,0"/>
                        <TextBlock Text="Verify your identity to continue"
                                   FontSize="12"
                                   Foreground="#8B8BA7"
                                   HorizontalAlignment="Center"
                                   Margin="0,14,0,0"/>
                    </StackPanel>

                    <!-- Lockout panel -->
                    <Border x:Name="LockoutPanel"
                            Visibility="Collapsed"
                            Background="#1A1200"
                            BorderBrush="#F59E0B"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16,14"
                            Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Too many wrong attempts"
                                       Foreground="#F59E0B"
                                       FontWeight="Bold"
                                       FontSize="13"/>
                            <TextBlock x:Name="LockoutCountdownText"
                                       Foreground="#F59E0B"
                                       FontSize="12"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Windows Hello -->
                    <StackPanel x:Name="HelloSection" Visibility="Collapsed">
                        <Button Content="🔒  Use Windows Hello"
                                Style="{StaticResource PrimaryBtn}"
                                x:Name="HelloBtn"
                                Click="HelloBtn_Click"
                                Margin="0,0,0,4"/>
                        <TextBlock x:Name="HelloErrorText"
                                   Visibility="Collapsed"
                                   Foreground="{StaticResource ErrorBrush}"
                                   FontSize="12"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap"/>
                        <Grid Margin="0,20,0,20">
                            <Separator Background="#1E1E32"/>
                            <TextBlock Text="or"
                                       Background="{StaticResource BgBrush}"
                                       Foreground="#8B8BA7"
                                       FontSize="11"
                                       HorizontalAlignment="Center"
                                       Padding="10,0"/>
                        </Grid>
                    </StackPanel>

                    <!-- ── PIN ── -->
                    <StackPanel x:Name="PinSection" Margin="0,0,0,20">

                        <TextBlock Text="PIN"
                                   Foreground="#8B8BA7"
                                   FontSize="11" FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>

                            <!-- PIN input with eye overlay -->
                            <Grid Grid.Column="0" Margin="0,0,8,0">
                                <PasswordBox x:Name="PinBox"
                                             Style="{StaticResource InputBox}"
                                             MaxLength="8"
                                             KeyDown="PinBox_KeyDown"
                                             Padding="10,0,32,0"
                                             VerticalContentAlignment="Center"/>
                                <TextBox x:Name="PinBoxReveal"
                                         Visibility="Collapsed"
                                         Background="#12121E"
                                         Foreground="#F8F8FF"
                                         BorderBrush="#1E1E32"
                                         BorderThickness="1"
                                         Height="40"
                                         FontSize="14"
                                         Padding="10,0,32,0"
                                         VerticalContentAlignment="Center"
                                         MaxLength="8"/>
                                <Button x:Name="PinEyeBtn"
                                        Content="◉"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Margin="0,0,6,0"
                                        Width="22" Height="22"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="#8B8BA7"
                                        FontSize="13"
                                        Cursor="Hand"
                                        IsTabStop="False"
                                        Click="PinEye_Click"/>
                            </Grid>

                            <Button Grid.Column="1"
                                    Content="Unlock"
                                    Style="{StaticResource PrimaryBtn}"
                                    Click="PinBtn_Click"
                                    x:Name="PinBtn"/>
                        </Grid>

                        <TextBlock x:Name="PinErrorText"
                                   Visibility="Collapsed"
                                   Foreground="{StaticResource ErrorBrush}"
                                   FontSize="12"
                                   Margin="0,6,0,0"
                                   TextWrapping="Wrap"/>

                    </StackPanel>

                    <!-- Divider -->
                    <Grid Margin="0,0,0,20">
                        <Separator Background="#1E1E32"/>
                        <TextBlock Text="or"
                                   Background="{StaticResource BgBrush}"
                                   Foreground="#8B8BA7"
                                   FontSize="11"
                                   HorizontalAlignment="Center"
                                   Padding="10,0"/>
                    </Grid>

                    <!-- ── Password ── -->
                    <StackPanel x:Name="PasswordSection" Margin="0,0,0,24">

                        <TextBlock Text="PASSWORD"
                                   Foreground="#8B8BA7"
                                   FontSize="11" FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>

                            <!-- Password input with eye overlay -->
                            <Grid Grid.Column="0" Margin="0,0,8,0">
                                <PasswordBox x:Name="PasswordBox"
                                             Style="{StaticResource InputBox}"
                                             KeyDown="PasswordBox_KeyDown"
                                             Padding="10,0,32,0"
                                             VerticalContentAlignment="Center"/>
                                <TextBox x:Name="PwdBoxReveal"
                                         Visibility="Collapsed"
                                         Background="#12121E"
                                         Foreground="#F8F8FF"
                                         BorderBrush="#1E1E32"
                                         BorderThickness="1"
                                         Height="40"
                                         FontSize="14"
                                         Padding="10,0,32,0"
                                         VerticalContentAlignment="Center"/>
                                <Button x:Name="PwdEyeBtn"
                                        Content="◉"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Margin="0,0,6,0"
                                        Width="22" Height="22"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="#8B8BA7"
                                        FontSize="13"
                                        Cursor="Hand"
                                        IsTabStop="False"
                                        Click="PwdEye_Click"/>
                            </Grid>

                            <Button Grid.Column="1"
                                    Content="Unlock"
                                    Style="{StaticResource PrimaryBtn}"
                                    Click="PasswordBtn_Click"
                                    x:Name="PasswordBtn"/>
                        </Grid>

                        <TextBlock x:Name="PasswordErrorText"
                                   Visibility="Collapsed"
                                   Foreground="{StaticResource ErrorBrush}"
                                   FontSize="12"
                                   Margin="0,6,0,0"
                                   TextWrapping="Wrap"/>

                    </StackPanel>

                    <!-- Recovery toggle -->
                    <Button x:Name="RecoveryToggleBtn"
                            Content="Forgot? Use recovery code"
                            Style="{StaticResource LinkBtn}"
                            HorizontalAlignment="Center"
                            Click="RecoveryToggleBtn_Click"
                            Margin="0,0,0,14"/>

                    <!-- Recovery section -->
                    <StackPanel x:Name="RecoverySection" Visibility="Collapsed">
                        <Border Background="#0A0A14"
                                BorderBrush="#1E1E32"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14,12"
                                Margin="0,0,0,10">
                            <TextBlock Text="Enter your recovery code exactly as it was shown during setup. Dashes are optional."
                                       Foreground="#8B8BA7"
                                       FontSize="12"
                                       TextWrapping="Wrap"/>
                        </Border>
                        <TextBox x:Name="RecoveryCodeBox"
                                 Background="#12121E"
                                 Foreground="#F8F8FF"
                                 BorderBrush="#1E1E32"
                                 BorderThickness="1"
                                 Height="40"
                                 FontSize="14"
                                 FontFamily="Consolas"
                                 Padding="10,0"
                                 CharacterCasing="Upper"
                                 Margin="0,0,0,8"
                                 KeyDown="RecoveryCodeBox_KeyDown"/>
                        <Button Content="Recover Access"
                                Style="{StaticResource PrimaryBtn}"
                                Background="#991B1B"
                                Click="RecoveryBtn_Click"
                                x:Name="RecoveryBtn"/>
                        <TextBlock x:Name="RecoveryErrorText"
                                   Visibility="Collapsed"
                                   Foreground="{StaticResource ErrorBrush}"
                                   FontSize="12"
                                   Margin="0,6,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

        </Grid>
    </Border>
</Window>