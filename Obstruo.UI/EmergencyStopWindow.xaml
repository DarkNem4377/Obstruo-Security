<Window x:Class="Obstruo.UI.EmergencyStopWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pause Protection"
        Icon="/Resources/obstruo.ico"
        Width="440" Height="400"
        MinWidth="440" MinHeight="400"
        MaxWidth="440"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Foreground"      Value="#F8F8FF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#0D0D14" BorderBrush="#3D2A00" BorderThickness="1" CornerRadius="10">
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="#12121E" CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="DragBar_MouseLeftButtonDown">
                <Grid Height="44">
                    <TextBlock Text="PAUSE PROTECTION" FontFamily="Segoe UI" FontSize="12"
                               FontWeight="Bold" Foreground="#F59E0B"
                               VerticalAlignment="Center" Margin="18,0,0,0"/>
                    <Button x:Name="CloseBtn" Content="✕" Width="44" Height="44"
                            HorizontalAlignment="Right" FontSize="13"
                            Foreground="#6870a0" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Click="CloseBtn_Click"/>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="24,20,24,22">

                <TextBlock Text="Temporarily pause filtering"
                           FontFamily="Segoe UI" FontSize="16" FontWeight="Bold"
                           Foreground="#F8F8FF" Margin="0,0,0,10"/>

                <TextBlock TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="12"
                           Foreground="#8B8BA7" LineHeight="18" Margin="0,0,0,18">
                    All web filtering will be disabled for a limited time and then resume
                    automatically. You can also resume early from the dashboard.
                    Enter your PIN or password to confirm.
                </TextBlock>

                <TextBlock Text="PIN OR PASSWORD" FontFamily="Segoe UI" FontSize="10"
                           FontWeight="Bold" Foreground="#8B8BA7" Margin="0,0,0,6"/>

                <Border Background="#12121E" BorderBrush="#1E1E32" BorderThickness="1" CornerRadius="6">
                    <PasswordBox x:Name="CredentialBox" FontFamily="Segoe UI" FontSize="14"
                                 Foreground="#F8F8FF" Background="Transparent" BorderThickness="0"
                                 Padding="12,10" VerticalContentAlignment="Center"
                                 KeyDown="CredentialBox_KeyDown"/>
                </Border>

                <TextBlock x:Name="ErrorText" Visibility="Collapsed" TextWrapping="Wrap"
                           FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                           Foreground="#EF4444" Margin="2,10,0,0"/>

                <TextBlock x:Name="StatusText" Visibility="Collapsed" TextWrapping="Wrap"
                           FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                           Foreground="#F59E0B" Margin="2,10,0,0"/>

                <Grid Margin="0,22,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="CancelBtn" Grid.Column="0" Content="Cancel"
                            Style="{StaticResource PrimaryBtn}" Background="#1E1E32"
                            Click="CancelBtn_Click"/>

                    <Button x:Name="PauseBtn" Grid.Column="2" Content="Pause Protection"
                            Style="{StaticResource PrimaryBtn}" Background="#B45309"
                            Click="PauseBtn_Click"/>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</Window>
