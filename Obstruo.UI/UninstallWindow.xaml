<Window x:Class="Obstruo.UI.UninstallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Uninstall Obstruo"
        Icon="/Resources/obstruo.ico"
        Width="440" Height="430"
        MinWidth="440" MinHeight="430"
        MaxWidth="440"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#01050C" BorderBrush="#1B1F2C" BorderThickness="1" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="#000104" CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="DragBar_MouseLeftButtonDown">
                <Grid Height="52">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                        <Image Source="/Resources/obstruo-logo.png" Height="30" Width="30"
                               VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                        <Rectangle Width="1" Height="26" Fill="#1B1F2C" Margin="12,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="OBSTRUO" FontFamily="Segoe UI" FontSize="13"
                                       FontWeight="Bold" Foreground="#FFFFFF"/>
                            <TextBlock Text="UNINSTALL" FontFamily="Segoe UI" FontSize="9"
                                       FontWeight="Bold" Foreground="#8A6A4A" Margin="0,1,0,0"/>
                        </StackPanel>
                        <Rectangle Width="1" Height="26" Fill="#1B1F2C" Margin="14,0"/>
                        <Border Background="#1a0404" BorderBrush="#7a1a1a" BorderThickness="1"
                                CornerRadius="99" Padding="12,4" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="7" Height="7" Fill="#ff8080"
                                         VerticalAlignment="Center" Margin="0,0,7,0"/>
                                <TextBlock Text="REMOVAL" FontFamily="Segoe UI" FontSize="10"
                                           FontWeight="Bold" Foreground="#ff8080"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <Button x:Name="CloseBtn" Content="✕" Width="48" Height="52"
                            HorizontalAlignment="Right" FontSize="13"
                            Foreground="#6870A0" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Click="CloseBtn_Click"/>
                </Grid>
            </Border>

            <!-- Gold divider line -->
            <Rectangle Grid.Row="1" Height="1">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="#4A3820" Offset="0.2"/>
                        <GradientStop Color="#8A6A4A" Offset="0.5"/>
                        <GradientStop Color="#4A3820" Offset="0.8"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <StackPanel Grid.Row="2" Margin="24,20,24,22">

                <TextBlock Text="This will remove Obstruo completely"
                           FontFamily="Segoe UI" FontSize="16" FontWeight="Bold"
                           Foreground="#E8EAF0" Margin="0,0,0,10"/>

                <TextBlock TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="12"
                           Foreground="#8890B8" LineHeight="18" Margin="0,0,0,18">
                    Your original DNS settings will be restored and DNS-over-HTTPS blocking removed.
                    The Obstruo service and all filtering will be permanently removed from this
                    computer. Enter your PIN or password to confirm.
                </TextBlock>

                <TextBlock Text="PIN OR PASSWORD" FontFamily="Segoe UI" FontSize="10"
                           FontWeight="Bold" Foreground="#6870A0" Margin="0,0,0,6"/>

                <Border Background="#050B15" BorderBrush="#1B1F2C" BorderThickness="1" CornerRadius="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <PasswordBox x:Name="CredentialBox" Grid.Column="0"
                                     FontFamily="Consolas" FontSize="14"
                                     Foreground="#E8EAF0" Background="Transparent" BorderThickness="0"
                                     CaretBrush="#6A5CFF"
                                     Padding="12,10" VerticalContentAlignment="Center"
                                     PasswordChanged="CredentialBox_PasswordChanged"
                                     KeyDown="CredentialBox_KeyDown"/>

                        <TextBox x:Name="CredentialVisibleBox" Grid.Column="0"
                                 Visibility="Collapsed"
                                 FontFamily="Consolas" FontSize="14"
                                 Foreground="#E8EAF0" Background="Transparent" BorderThickness="0"
                                 CaretBrush="#6A5CFF"
                                 Padding="12,10" VerticalContentAlignment="Center"
                                 TextChanged="CredentialVisibleBox_TextChanged"
                                 KeyDown="CredentialBox_KeyDown"/>

                        <Button x:Name="RevealBtn" Grid.Column="1"
                                Width="40" Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Click="RevealBtn_Click"
                                ToolTip="Show or hide credential">
                            <Path x:Name="RevealIcon"
                                  Data="M12,9A3,3 0 0,1 15,12A3,3 0 0,1 12,15A3,3 0 0,1 9,12A3,3 0 0,1 12,9M12,4.5C17,4.5 21.27,7.61 23,12C21.27,16.39 17,19.5 12,19.5C7,19.5 2.73,16.39 1,12C2.73,7.61 7,4.5 12,4.5Z"
                                  Fill="#6870A0" Width="18" Height="18" Stretch="Uniform"/>
                        </Button>
                    </Grid>
                </Border>

                <TextBlock x:Name="ErrorText" Visibility="Collapsed" TextWrapping="Wrap"
                           FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                           Foreground="#ff8080" Margin="2,10,0,0"/>

                <TextBlock x:Name="StatusText" Visibility="Collapsed" TextWrapping="Wrap"
                           FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                           Foreground="#D4AA7C" Margin="2,10,0,0"/>

                <Grid Margin="0,22,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="CancelBtn" Grid.Column="0" Content="Cancel"
                            Style="{StaticResource PrimaryBtn}"
                            Background="#050B15" BorderBrush="#1B1F2C" Foreground="#8890B8"
                            Click="CancelBtn_Click"/>

                    <Button x:Name="UninstallBtn" Grid.Column="2" Content="Uninstall Obstruo"
                            Style="{StaticResource PrimaryBtn}"
                            Background="#1a0404" BorderBrush="#7a1a1a" Foreground="#ff8080"
                            Click="UninstallBtn_Click"/>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</Window>