<Window x:Class="Obstruo.UI.DomainCredentialDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Obstruo"
        Icon="/Resources/obstruo.ico"
        Width="440" Height="430"
        MinWidth="440" MinHeight="430"
        MaxWidth="440"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Foreground"      Value="#F8F8FF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#0D0D14" BorderBrush="#1E1E32" BorderThickness="1" CornerRadius="10">
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="#12121E" CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="DragBar_MouseLeftButtonDown">
                <Grid Height="44">
                    <TextBlock x:Name="TitleText" Text="CONFIRM ACTION" FontFamily="Segoe UI" FontSize="12"
                               FontWeight="Bold" Foreground="#B0A8FF"
                               VerticalAlignment="Center" Margin="18,0,0,0"/>
                    <Button x:Name="CloseBtn" Content="✕" Width="44" Height="44"
                            HorizontalAlignment="Right" FontSize="13"
                            Foreground="#6870a0" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Click="CloseBtn_Click"/>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="24,20,24,22">

                <TextBlock x:Name="DescriptionText" TextWrapping="Wrap"
                           FontFamily="Segoe UI" FontSize="12"
                           Foreground="#8B8BA7" LineHeight="18" Margin="0,0,0,18"/>

                <TextBlock x:Name="DomainLabel" Text="DOMAIN" FontFamily="Segoe UI" FontSize="10"
                           FontWeight="Bold" Foreground="#8B8BA7" Margin="0,0,0,6"/>

                <Border x:Name="DomainBorder" Background="#12121E" BorderBrush="#1E1E32" BorderThickness="1"
                        CornerRadius="6" Margin="0,0,0,14">
                    <TextBox x:Name="DomainBox" FontFamily="Cascadia Code" FontSize="13"
                             Foreground="#F8F8FF" Background="Transparent" BorderThickness="0"
                             Padding="12,10" VerticalContentAlignment="Center"
                             CaretBrush="#F8F8FF"/>
                </Border>

                <StackPanel x:Name="DurationPanel" Visibility="Collapsed">
                    <TextBlock Text="DURATION" FontFamily="Segoe UI" FontSize="10"
                               FontWeight="Bold" Foreground="#8B8BA7" Margin="0,0,0,6"/>
                    <ComboBox x:Name="DurationCombo" Height="34" Foreground="#0D0D14" Margin="0,0,0,14">
                        <ComboBoxItem Content="Permanent" Tag="0" IsSelected="True"/>
                        <ComboBoxItem Content="15 minutes" Tag="15"/>
                        <ComboBoxItem Content="1 hour" Tag="60"/>
                        <ComboBoxItem Content="1 day" Tag="1440"/>
                        <ComboBoxItem Content="1 week" Tag="10080"/>
                    </ComboBox>
                </StackPanel>

                <TextBlock Text="PIN OR PASSWORD" FontFamily="Segoe UI" FontSize="10"
                           FontWeight="Bold" Foreground="#8B8BA7" Margin="0,0,0,6"/>

                <Border Background="#12121E" BorderBrush="#1E1E32" BorderThickness="1" CornerRadius="6">
                    <PasswordBox x:Name="CredentialBox" FontFamily="Segoe UI" FontSize="14"
                                 Foreground="#F8F8FF" Background="Transparent" BorderThickness="0"
                                 Padding="12,10" VerticalContentAlignment="Center"
                                 KeyDown="CredentialBox_KeyDown"/>
                </Border>

                <TextBlock x:Name="ErrorText" Visibility="Collapsed" TextWrapping="Wrap"
                           FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                           Foreground="#EF4444" Margin="2,10,0,0"/>

                <TextBlock x:Name="StatusText" Visibility="Collapsed" TextWrapping="Wrap"
                           FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                           Foreground="#F59E0B" Margin="2,10,0,0"/>

                <Grid Margin="0,22,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="CancelBtn" Grid.Column="0" Content="Cancel"
                            Style="{StaticResource PrimaryBtn}" Background="#1E1E32"
                            Click="CancelBtn_Click"/>

                    <Button x:Name="ConfirmBtn" Grid.Column="2" Content="Confirm"
                            Style="{StaticResource PrimaryBtn}" Background="#3F2D9B"
                            Click="ConfirmBtn_Click"/>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</Window>
